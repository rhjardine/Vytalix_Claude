      "request": {
        "method": "POST",
        "url": "{{base_url}}/assessments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"123\",\n  \"channel\": \"disglobal_app\",\n  \"consentAccepted\": true\n}"
        }
      }
    },
    {
