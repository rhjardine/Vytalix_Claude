      "request": {
        "method": "POST",
        "url": "{{base_url}}/assessments/{{assessmentId}}/scan"
      }
    },
    {
      "name": "Questionnaire",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/assessments/{{assessmentId}}/questionnaire"
      }
    },
    {
      "name": "Evaluate Risk",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/assessments/{{assessmentId}}/evaluate"
      }
    },
    {
      "name": "Create Appointment",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/appointments"
      }
    },
    {
      "name": "Payment Intent",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/payments/intent"
      }
    },
    {
      "name": "Payment Webhook",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/webhooks/disglobal/payment-confirmed"
      }
