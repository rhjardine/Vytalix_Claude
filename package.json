{
  "name": "vytalix-clinical-engine",
  "version": "0.9.0-demo",
  "description": "Clinical intelligence layer \u2014 observations to actionable decisions",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "api:dev": "ts-node-dev --respawn --transpile-only --project tsconfig.server.json src/server.ts",
    "api:build": "tsc --project tsconfig.server.json",
    "api:start": "node dist/server.js",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:rls": "psql $DATABASE_URL -f prisma/migration_rls.sql",
    "db:seed": "ts-node --project tsconfig.server.json src/demo/seed-demo.ts",
    "db:studio": "prisma studio",
    "auth:bootstrap": "ts-node --project tsconfig.server.json src/auth/bootstrap.ts",
    "demo:check": "ts-node --project tsconfig.server.json scripts/demo-check.ts",
    "demo:reset": "ts-node --project tsconfig.server.json src/demo/seed-demo.ts && ts-node --project tsconfig.server.json scripts/demo-check.ts",
    "e2e": "ts-node --project tsconfig.server.json scripts/e2e-flow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit --project tsconfig.server.json"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "next": "14.0.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "prisma": "^5.7.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "@types/bcryptjs": "^2.4.6"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --project tsconfig.server.json prisma/seed.ts"
  }
}