// =============================================================================
// prisma/schema.prisma — CANONICAL unified schema
// Merges: base clinical schema + v2 platform extensions
// Run: npx prisma migrate dev --name "vytalix_platform_v2"
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// DOMAIN 1 — TENANTS
// =============================================================================
model Tenant {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(100)
  isActive    Boolean @default(true)

  // Billing & commercial
  monthlyApiLimit   Int      @default(0)        // 0 = unlimited (Enterprise)
  revenueShareRatio Decimal  @default(0.30) @db.Decimal(4, 2)  // Vytalix share
  plan              String   @default("STARTER") @db.VarChar(50)

  // Webhook config (for outbound events → Disglobal)
  webhookUrl    String? @db.VarChar(500)
  webhookSecret String? @db.VarChar(64)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("tenants")
}

// =============================================================================
// DOMAIN 2 — USERS (Physicians, Coordinators)
// =============================================================================
model User {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @db.Uuid
  email      String @db.VarChar(255)
  name       String @db.VarChar(255)
  role       UserRole @default(PHYSICIAN)
  passwordHash String @db.VarChar(255)
  isActive   Boolean @default(true)
  lastLoginAt DateTime? @db.Timestamptz
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

// =============================================================================
// DOMAIN 3 — PATIENTS
// =============================================================================
model Patient {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String        @db.Uuid
  mrn          String        @db.VarChar(100)     // Medical Record Number
  firstName    String        @db.VarChar(255)
  lastName     String        @db.VarChar(255)
  dateOfBirth  DateTime      @db.Date
  biologicalSex BiologicalSex
  isActive     Boolean       @default(true)
  status       PatientStatus @default(ACTIVE)

  // External IDs (Disglobal pseudonymous ref, EMR ID, etc.)
  externalIds  Json?         @db.JsonB            // { "disglobal_ref": "DISG-xxx", "emr_id": "yyy" }

  createdAt    DateTime      @default(now()) @db.Timestamptz
  updatedAt    DateTime      @updatedAt @db.Timestamptz

  @@unique([tenantId, mrn])
  @@index([tenantId, status])
  @@index([tenantId, biologicalSex])
  @@map("patients")
}

// =============================================================================
// DOMAIN 4 — PATIENT HEALTH SNAPSHOTS (updated by DB trigger)
// =============================================================================
model PatientHealthSnapshot {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @db.Uuid
  patientId String @unique @db.Uuid

  // Core clinical snapshot (Framingham inputs)
  latestTotalCholesterol Decimal? @db.Decimal(7, 2)
  latestHdlMgDl          Decimal? @db.Decimal(7, 2)
  latestLdlMgDl          Decimal? @db.Decimal(7, 2)
  latestSystolicBp       Decimal? @db.Decimal(7, 2)
  latestFastingGlucose   Decimal? @db.Decimal(7, 2)
  latestHbA1c            Decimal? @db.Decimal(5, 2)
  latestBmi              Decimal? @db.Decimal(5, 2)
  latestCreatinine       Decimal? @db.Decimal(7, 4)
  latestHsCrp            Decimal? @db.Decimal(7, 4)
  isOnAntihypertensives  Boolean  @default(false)
  isSmoker               Boolean  @default(false)
  hasDiabetes            Boolean  @default(false)
  ageAtSnapshot          Int?

  // Platform v2 extensions
  latestBiophysicsAge    Decimal? @db.Decimal(5, 1)
  latestBiophysicsDelta  Decimal? @db.Decimal(5, 1)
  lastBiophysicsAt       DateTime? @db.Timestamptz
  latestPreventiveScore  Int?
  latestPreventiveTier   String?  @db.VarChar(20)

  snapshotVersion Int      @default(1)
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@map("patient_health_snapshots")
}

// =============================================================================
// DOMAIN 5 — CLINICAL OBSERVATIONS (TimescaleDB hypertable)
// =============================================================================
model ClinicalObservation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  patientId  String   @db.Uuid
  loincCode  String   @db.VarChar(20)
  value      Decimal  @db.Decimal(12, 4)
  unit       String   @db.VarChar(30)
  observedAt DateTime @db.Timestamptz
  source     String   @db.VarChar(50)  // "manual", "external_api", "emr", "funnel"
  rawPayload Json?    @db.JsonB
  createdAt  DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, observedAt(sort: Desc)])
  @@index([tenantId, loincCode, observedAt(sort: Desc)])
  @@map("clinical_observations")
}

// =============================================================================
// DOMAIN 6 — RISK SCORES
// =============================================================================
model RiskScore {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  patientId        String   @db.Uuid
  scoreType        String   @db.VarChar(50)     // "CARDIOVASCULAR_10Y"
  value            Decimal  @db.Decimal(6, 4)
  valuePercent     Decimal  @db.Decimal(5, 2)
  riskCategory     String   @db.VarChar(20)     // "LOW"|"MODERATE"|"HIGH"|"VERY_HIGH"
  algorithmId      String   @db.VarChar(50)
  algorithmVersion String   @db.VarChar(20)
  inputSnapshot    Json     @db.JsonB
  computedAt       DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, scoreType, computedAt(sort: Desc)])
  @@map("risk_scores")
}

// =============================================================================
// DOMAIN 7 — DECISIONS + RECOMMENDATIONS (physician-in-the-loop)
// =============================================================================
model DecisionTrace {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  patientId         String   @db.Uuid
  correlationId     String   @db.Uuid
  riskCategory      String   @db.VarChar(20)
  recommendations   Json     @db.JsonB
  rulesEvaluated    Int
  rulesTriggered    Int
  generatedAt       DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, generatedAt(sort: Desc)])
  @@map("decision_traces")
}

model Recommendation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  patientId   String   @db.Uuid
  traceId     String   @db.Uuid
  ruleId      String   @db.VarChar(20)
  urgency     String   @db.VarChar(10)
  body        String   @db.Text
  status      RecommendationStatus @default(PENDING)
  reviewedBy  String?  @db.Uuid
  reviewedAt  DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, status])
  @@map("recommendations")
}

// =============================================================================
// DOMAIN 8 — BIOLOGICAL AGE ASSESSMENTS (immutable)
// =============================================================================
model BiologicalAgeAssessment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  patientId        String   @db.Uuid
  assessmentType   AssessmentType
  chronologicalAge Int
  biologicalAge    Decimal  @db.Decimal(5, 1)
  differentialAge  Decimal  @db.Decimal(5, 1)
  ageStatus        AgeStatus
  partialAgesSnapshot Json  @db.JsonB
  inputSnapshot    Json     @db.JsonB
  algorithmId      String   @db.VarChar(50)
  algorithmVersion String   @db.VarChar(20)
  conductedBy      String?  @db.Uuid
  notes            String?  @db.Text
  assessedAt       DateTime @default(now()) @db.Timestamptz
  createdAt        DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, assessmentType, assessedAt(sort: Desc)])
  @@index([tenantId, ageStatus])
  @@map("biological_age_assessments")
}

// =============================================================================
// DOMAIN 9 — PREVENTIVE SCORES
// =============================================================================
model PreventiveScore {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  patientId        String    @db.Uuid
  compositeScore   Int
  scoreTier        ScoreTier
  cardiovascularScore Int?
  metabolicScore      Int?
  biologicalAgeScore  Int?
  lifestyleScore      Int?
  inputSnapshot    Json     @db.JsonB
  algorithmId      String   @db.VarChar(50)
  algorithmVersion String   @db.VarChar(20)
  computedAt       DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, computedAt(sort: Desc)])
  @@map("preventive_scores")
}

// =============================================================================
// DOMAIN 10 — ENGAGEMENT
// =============================================================================
model EngagementEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  patientId  String   @db.Uuid
  actorId    String?  @db.Uuid
  eventType  EngagementEventType
  payload    Json     @db.JsonB
  source     String   @db.VarChar(50)
  occurredAt DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, occurredAt(sort: Desc)])
  @@index([tenantId, eventType, occurredAt(sort: Desc)])
  @@map("engagement_events")
}

model EngagementScore {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @db.Uuid
  patientId          String   @unique @db.Uuid
  score              Int
  tier               EngagementTier
  streak             Int      @default(0)
  lastEventAt        DateTime? @db.Timestamptz
  totalEvents        Int      @default(0)
  testCompletionRate Decimal? @db.Decimal(4, 1)
  recommendationAck  Decimal? @db.Decimal(4, 1)
  updatedAt          DateTime @updatedAt @db.Timestamptz

  @@index([tenantId, tier])
  @@map("engagement_scores")
}

// =============================================================================
// DOMAIN 11 — REFERRAL EVENTS
// =============================================================================
model ReferralEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  patientId      String   @db.Uuid
  referralType   ReferralType
  urgency        Urgency
  triggerReason  String   @db.VarChar(255)
  triggerPayload Json     @db.JsonB
  ctaPayload     Json     @db.JsonB
  ctaDeliveredAt DateTime? @db.Timestamptz
  ctaClickedAt   DateTime? @db.Timestamptz
  convertedAt    DateTime? @db.Timestamptz
  convertedValue Decimal? @db.Decimal(10, 2)
  status         ReferralStatus @default(GENERATED)
  generatedAt    DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, patientId, generatedAt(sort: Desc)])
  @@index([tenantId, status])
  @@map("referral_events")
}

// =============================================================================
// DOMAIN 12 — API KEYS
// =============================================================================
model ApiKey {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  keyHash       String   @unique @db.VarChar(64)
  keyPrefix     String   @db.VarChar(20)
  permissions   Json     @db.JsonB
  rateLimitTier RateLimitTier @default(STANDARD)
  lastUsedAt    DateTime? @db.Timestamptz
  requestCount  BigInt   @default(0)
  isActive      Boolean  @default(true)
  expiresAt     DateTime? @db.Timestamptz
  createdBy     String   @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz
  revokedAt     DateTime? @db.Timestamptz
  revokedBy     String?  @db.Uuid

  @@index([tenantId, isActive])
  @@map("api_keys")
}

// =============================================================================
// DOMAIN 13 — CONSENT RECORDS
// =============================================================================
model ConsentRecord {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  patientId       String   @db.Uuid
  consentType     ConsentType
  legalBasis      String   @db.VarChar(100)
  documentVersion String   @db.VarChar(20)
  documentUrl     String   @db.VarChar(500)
  consentMethod   String   @db.VarChar(50)
  consentedAt     DateTime @default(now()) @db.Timestamptz
  expiresAt       DateTime? @db.Timestamptz
  withdrawnAt     DateTime? @db.Timestamptz
  withdrawnBy     String?  @db.Uuid
  ipAddress       String?  @db.VarChar(45)
  userAgent       String?  @db.VarChar(500)

  @@index([tenantId, patientId, consentType])
  @@map("consent_records")
}

// =============================================================================
// DOMAIN 14 — CALCULATION VERSIONS
// =============================================================================
model CalculationVersion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  algorithmId  String   @db.VarChar(50)
  version      String   @db.VarChar(20)
  description  String   @db.Text
  paramsSnapshot Json   @db.JsonB
  isActive     Boolean  @default(false)
  activatedAt  DateTime? @db.Timestamptz
  deprecatedAt DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz

  @@unique([algorithmId, version])
  @@index([algorithmId, isActive])
  @@map("calculation_versions")
}

// =============================================================================
// DOMAIN 15 — BIOPHYSICS BOARDS (scoring tables)
// =============================================================================
model BiophysicsBoard {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  measurementKey String   @db.VarChar(50)
  biologicalSex  BiologicalSex
  isAthlete      Boolean  @default(false)
  ranges         Json     @db.JsonB
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  @@unique([tenantId, measurementKey, biologicalSex, isAthlete])
  @@index([tenantId, measurementKey])
  @@map("biophysics_boards")
}

// =============================================================================
// DOMAIN 16 — AUDIT LOGS (append-only)
// =============================================================================
model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  actorId      String?  @db.Uuid
  actorRole    String?  @db.VarChar(50)
  resourceType String   @db.VarChar(50)
  resourceId   String   @db.VarChar(255)
  action       String   @db.VarChar(100)
  diff         Json?    @db.JsonB
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, resourceType, resourceId])
  @@map("audit_logs")
}

// =============================================================================
// DOMAIN 17 — BILLING EVENTS (metering)
// =============================================================================
model BillingEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  keyId         String   @db.Uuid
  operation     String   @db.VarChar(50)
  unitCount     Int
  unitPriceCents Int
  totalCents    Int
  statusCode    Int
  durationMs    Int      @default(0)
  correlationId String?  @db.VarChar(36)
  occurredAt    DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, operation, occurredAt(sort: Desc)])
  @@map("billing_events")
}

// =============================================================================
// DOMAIN 18 — FUNNEL (public lead capture, no PHI)
// =============================================================================
model FunnelLead {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  email         String?  @db.VarChar(255)  // Optional — pseudonymous until consent
  phone         String?  @db.VarChar(30)
  firstName     String?  @db.VarChar(100)
  source        String   @db.VarChar(100)  // "disglobal_app", "landing_page", "partner"
  utmSource     String?  @db.VarChar(100)
  utmCampaign   String?  @db.VarChar(100)
  utmMedium     String?  @db.VarChar(100)
  status        FunnelStatus @default(CAPTURED)
  currentStep   String   @db.VarChar(50)   // "landing"|"vitality_test"|"results"|"booking"
  convertedToPatientId String? @db.Uuid    // Set when lead becomes patient
  lastActivityAt DateTime? @db.Timestamptz
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  assessments   FunnelAssessment[]
  bookings      FunnelBooking[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("funnel_leads")
}

model FunnelAssessment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  leadId          String   @db.Uuid
  chronologicalAge Int
  biologicalAge   Decimal  @db.Decimal(5, 1)
  differentialAge Decimal  @db.Decimal(5, 1)
  ageStatus       AgeStatus
  measurementsSnapshot Json @db.JsonB
  partialAges     Json     @db.JsonB
  ctaShown        Boolean  @default(false)
  ctaClicked      Boolean  @default(false)
  assessedAt      DateTime @default(now()) @db.Timestamptz

  lead            FunnelLead @relation(fields: [leadId], references: [id])

  @@index([tenantId, leadId])
  @@index([tenantId, assessedAt(sort: Desc)])
  @@map("funnel_assessments")
}

model FunnelBooking {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  leadId          String   @db.Uuid
  bookingType     String   @db.VarChar(50)  // "ONLINE_CONSULT"|"IN_PERSON"|"LAB_PANEL"
  scheduledAt     DateTime? @db.Timestamptz
  timezone        String?  @db.VarChar(50)
  notes           String?  @db.Text
  status          BookingStatus @default(PENDING)
  confirmedAt     DateTime? @db.Timestamptz
  cancelledAt     DateTime? @db.Timestamptz
  reminderSentAt  DateTime? @db.Timestamptz
  createdAt       DateTime @default(now()) @db.Timestamptz

  lead            FunnelLead @relation(fields: [leadId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@map("funnel_bookings")
}

// =============================================================================
// ENUMS
// =============================================================================
enum UserRole {
  ADMIN
  PHYSICIAN
  COORDINATOR
  READONLY
}

enum BiologicalSex {
  MALE
  FEMALE
  INTERSEX
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RecommendationStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum AssessmentType {
  BIOPHYSICS
  BIOCHEMISTRY
  ORTHOMOLECULAR
  GENETIC
}

enum AgeStatus {
  REJUVENECIDO
  NORMAL
  ENVEJECIDO
}

enum ScoreTier {
  OPTIMAL
  GOOD
  MODERATE_RISK
  HIGH_RISK
  CRITICAL
}

enum EngagementEventType {
  TEST_COMPLETED
  TEST_STARTED
  RECOMMENDATION_VIEWED
  RECOMMENDATION_ACKNOWLEDGED
  GOAL_SET
  GOAL_ACHIEVED
  REPORT_DOWNLOADED
  REFERRAL_CTA_VIEWED
  REFERRAL_CTA_CLICKED
  SESSION_STARTED
  EDUCATION_CONTENT_VIEWED
}

enum EngagementTier {
  CHAMPION
  ENGAGED
  PASSIVE
  AT_RISK
  DORMANT
}

enum ReferralType {
  PREMIUM_CONSULT
  SPECIALIST_REFERRAL
  LAB_PANEL
  WELLNESS_PROGRAM
  FOLLOW_UP
}

enum ReferralStatus {
  GENERATED
  DELIVERED
  CLICKED
  CONVERTED
  DISMISSED
  EXPIRED
}

enum Urgency {
  URGENT
  SOON
  ROUTINE
}

enum RateLimitTier {
  STANDARD
  PROFESSIONAL
  ENTERPRISE
}

enum ConsentType {
  DATA_PROCESSING
  MARKETING
  RESEARCH
  THIRD_PARTY_SHARING
  BIOMETRIC_PROCESSING
}

enum FunnelStatus {
  CAPTURED
  ASSESSED
  BOOKED
  CONVERTED
  LOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ATTENDED
  NO_SHOW
  CANCELLED
}
