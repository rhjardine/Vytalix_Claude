// REEMPLAZAR la función mapDimensiones existente por esta versión
// que coincide con el shape EXACTO de calcularScore() en tests.tsx:

/*
/**
 * Traduce el campo `dimensiones` del calcularScore() existente
 * al contrato VitalityDimensions que espera el backend.
 *
 * calcularScore() devuelve:
 *   { dimensiones: { grupo1: number, grupo2: number, ... grupo5: number } }
 *
 * VitalityDimensions requiere:
 *   { energiaEstadoMental, suenoCognicion, composicionCorporal,
 *     signosEnvejecimiento, rangoEdad }
 *
 * @param dimensiones - Objeto dimensiones del resultado de calcularScore()
 *\/
export function mapDimensiones(
  dimensiones: Record<string, number>
): VitalityDimensions {
  return {
    energiaEstadoMental:  Math.round(dimensiones['grupo1'] ?? 0),
    suenoCognicion:       Math.round(dimensiones['grupo2'] ?? 0),
    composicionCorporal:  Math.round(dimensiones['grupo3'] ?? 0),
    signosEnvejecimiento: Math.round(dimensiones['grupo4'] ?? 0),
    rangoEdad:            Math.round(dimensiones['grupo5'] ?? 0),
  }
}
*/

