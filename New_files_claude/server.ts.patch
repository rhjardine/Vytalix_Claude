// ─── BLOQUE D: VARIABLES DE ENTORNO ──────────────────────────────────────────
// Agregar al .env.example del backend:

/*
# ── Funnel público ──────────────────────────────────────────────────────────
# API key que el frontend debe enviar en el header X-Funnel-Key
# Cambiar en producción — mínimo 32 caracteres alfanuméricos
FUNNEL_API_KEY=dev_funnel_key_CHANGE_IN_PRODUCTION_min32chars

# UUID del tenant por defecto para leads del funnel público
# En producción cada instancia tiene su propio tenant
DEFAULT_FUNNEL_TENANT_ID=a1b2c3d4-0000-4000-8000-000000000001

# ── AgeBot / Visión computacional ────────────────────────────────────────────
# Proveedor de análisis facial: mock | openai | azure | aws
# En desarrollo usar 'mock' — resultado determinístico, sin costo
VISION_PROVIDER=mock

# Solo si VISION_PROVIDER=openai:
# OPENAI_API_KEY=sk-...

# Solo si VISION_PROVIDER=azure:
# AZURE_FACE_KEY=...
# AZURE_FACE_ENDPOINT=https://...

# ── WhatsApp (canal primario Venezuela) ──────────────────────────────────────
# Número con código de país, sin +, sin espacios
WHATSAPP_NUMBER=58412XXXXXXX

# ── Exchange rate ─────────────────────────────────────────────────────────────
# Segundos de vida del cache Redis para las tasas BCV/paralelo
EXCHANGE_RATE_CACHE_TTL=60
*/

