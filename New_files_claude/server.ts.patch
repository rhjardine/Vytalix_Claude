/*
// Middleware de autenticación para el funnel público (API key pública)
// Separado del JWT médico — rutas /api/funnel/* no requieren sesión de médico
function funnelKeyMiddleware(req: Request, res: Response, next: NextFunction): void {
  const key      = req.headers['x-funnel-key'] as string | undefined
  const validKey = process.env.FUNNEL_API_KEY ?? 'dev_funnel_key'

  if (!key || key !== validKey) {
    res.status(401).json({
      type:   'https://api.vytalix.health/errors/401',
      title:  'Unauthorized',
      status: 401,
      detail: 'Missing or invalid X-Funnel-Key header',
    })
    return
  }
  next()
}
*/

