# =============================================================================
# Vytalix Clinical Intelligence Engine — Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ──
NODE_ENV=development
API_PORT=3001
LOG_LEVEL=info                    # debug | info | warn | error

# ── Database (PostgreSQL + TimescaleDB) ──
POSTGRES_DB=vytalix_dev
POSTGRES_USER=vytalix
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_MIN_16_CHARS
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vytalix:CHANGE_THIS_STRONG_PASSWORD_MIN_16_CHARS@localhost:5432/vytalix_dev

# ── Redis ──
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@localhost:6379

# ── Auth ──
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=8h

# ── CORS ──
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_PORT=3000

# ── Docker build ──
BUILD_TARGET=development          # development | production
DEV_MOUNT=.                       # mount source in dev mode
