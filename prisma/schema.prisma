// FASE 2 ENUMS
// =============================================================================

enum BiologicalAgeMethod {
  BIOPHYSICAL // Doctor Antivejez biophysical multi-system model
  PHENOTYPIC // Phenotypic age from clinical biomarkers (Levine-style)
  EPIGENETIC // Methylation clock (future external lab integration)
}

enum ConfidenceTier {
  HIGH
  MEDIUM
  LOW
}

enum ConsentType {
  DATA_PROCESSING // Process PHI for care delivery
  RESEARCH_USE // Use de-identified data for research
  WEARABLE_SYNC // Ingest device/wearable data
  MARKETING_COMMS // Engagement / marketing communications
  THIRD_PARTY_SHARING // Share with partners / insurers
}

enum ConsentStatus {
  GRANTED
  REVOKED
  EXPIRED
}

enum ConsentChannel {
  PORTAL // Patient self-service portal / PWA
  IN_PERSON // Staff-assisted, in clinic
  API // Captured via external integration
  IMPORTED // Migrated from a prior system
}

enum ProgramStatus {
