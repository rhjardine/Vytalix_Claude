  ACTIVE
  PAUSED
  ARCHIVED
}

enum ChallengeType {
  ACTIVITY // Steps, exercise minutes
  MEASUREMENT // Log a biomarker/observation
  ADHERENCE // Medication / protocol adherence
  EDUCATION // Complete a learning module
  HABIT // Sleep, hydration, nutrition habit
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PAUSED
}

enum EngagementEventType {
  ENROLLED
  CHALLENGE_STARTED
  CHALLENGE_COMPLETED
  MEASUREMENT_LOGGED
  POINTS_EARNED
  STREAK_ACHIEVED
  PROGRAM_COMPLETED
  DROPPED_OUT
}
